FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o dummy-evaluator ./dummy-evaluator
RUN go build -o queue-analysis-evaluator ./queue-analysis-evaluator
RUN go build -o blis-evaluator ./blis-evaluator

FROM alpine:3.20
WORKDIR /app
COPY --from=builder /app/dummy-evaluator .
COPY --from=builder /app/queue-analysis-evaluator .
COPY --from=builder /app/blis-evaluator .
COPY evaluator.sh .
RUN chmod +x evaluator.sh
EXPOSE 8081
ENTRYPOINT ["./evaluator.sh"]
